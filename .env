# NudgeKit SDK configuration (Expo inlines EXPO_PUBLIC_* into the bundle).
# Backend base URL is baked into the nudgekit-react-native SDK itself, so it
# doesn't need to be set here.

# Publishable NudgeKit API key (identifies the project). Required for home cards.
EXPO_PUBLIC_NUDGEKIT_API_KEY=lk_live_xxx

# Stable id for the current end user (used for targeting). Defaults to demo-user.
EXPO_PUBLIC_NUDGEKIT_USER_ID=demo-user
