# NudgeKit SDK configuration (Expo inlines EXPO_PUBLIC_* into the bundle).

# Publishable NudgeKit API key (identifies the project). Required for home cards.
EXPO_PUBLIC_NUDGEKIT_API_KEY=lk_live_xxx

# Journey owner — copy from admin panel "Builder ID" badge (not Build ID).
EXPO_PUBLIC_NUDGEKIT_BUILDER_ID=3

# Optional backend base URL override (defaults to SDK package config).
# EXPO_PUBLIC_NUDGEKIT_BASE_URL=http://localhost:8080

# Stable id for the current end user (used for targeting / enter-when).
EXPO_PUBLIC_NUDGEKIT_USER_ID=demo-user
